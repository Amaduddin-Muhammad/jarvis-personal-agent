datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String      @id @default(uuid())
  email        String      @unique
  passwordHash String
  faceHash     String?     // Biometric camera scan descriptors
  createdAt    DateTime    @default(now())
  
  preferences  Preference[]
  actionLogs   ActionLog[]
  notes        Note[]
  reminders    Reminder[]
  facts        Fact[]
}

model Preference {
  id      String @id @default(uuid())
  userId  String
  key     String
  value   String

  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
}

model ActionLog {
  id             String   @id @default(uuid())
  userId         String
  toolName       String
  arguments      String   // JSON stringified arguments
  permissionTier Int      // 0: Auto, 1: Trusted Auto, 2: Confirm, 3: Destructive
  authorized     Boolean
  outcome        String   // "success", "error", "denied", "crash"
  timestamp      DateTime @default(now())

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Note {
  id        String   @id @default(uuid())
  userId    String
  title     String
  content   String
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Reminder {
  id          String   @id @default(uuid())
  userId      String
  taskText    String
  triggerTime DateTime
  active      Boolean  @default(true)

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Fact {
  id        String   @id @default(uuid())
  userId    String
  subject   String
  predicate String
  object    String
  savedAt   DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
